# ─── Core ─────────────────────────────────────────────────────────
CAVALRY_ENV=development                    # development | test | production
CAVALRY_LOG_LEVEL=info                     # debug | info | warn | error
CAVALRY_WEB_URL=http://localhost:3000
CAVALRY_GATEWAY_URL=http://localhost:3001

# ─── Marketing site (public, baked into the web build) ────────────
NEXT_PUBLIC_CAVALRY_DOCS_URL=http://localhost:3002
NEXT_PUBLIC_CAVALRY_GITHUB_URL=https://github.com/zmeyer44/Cavalry

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgres://cavalry:cavalry@localhost:5432/cavalry_dev

# ─── Storage (artifacts + caches) ─────────────────────────────────
CAVALRY_STORAGE_PROVIDER=local             # local | s3 | r2
CAVALRY_STORAGE_LOCAL_DIR=./.cavalry-storage
CAVALRY_STORAGE_S3_BUCKET=
CAVALRY_STORAGE_S3_REGION=
CAVALRY_STORAGE_S3_ENDPOINT=               # for MinIO/R2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Auth (BetterAuth) ────────────────────────────────────────────
BETTER_AUTH_SECRET=replace-me-with-32-or-more-random-chars
BETTER_AUTH_URL=http://localhost:3000
CAVALRY_OIDC_ISSUER=
CAVALRY_OIDC_CLIENT_ID=
CAVALRY_OIDC_CLIENT_SECRET=

# ─── Gateway ──────────────────────────────────────────────────────
CAVALRY_GATEWAY_PORT=3001
CAVALRY_GATEWAY_CACHE_TTL=3600             # seconds
CAVALRY_GATEWAY_MAX_ARTIFACT_SIZE=52428800 # 50 MB

# ─── Upstream registry defaults ───────────────────────────────────
CAVALRY_UPSTREAM_TESSL_URL=https://tessl.io/registry
CAVALRY_UPSTREAM_GITHUB_TOKEN=             # optional, increases rate limits

# ─── Telemetry (opt-in) ───────────────────────────────────────────
CAVALRY_TELEMETRY_ENABLED=false
