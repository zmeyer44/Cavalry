{
  "name": "@cavalry/web-e2e",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "e2e": "pnpm --filter @cavalry/web build && playwright test",
    "e2e:quick": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:headed": "playwright test --headed",
    "e2e:install": "playwright install --with-deps chromium",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "echo 'run pnpm e2e instead' && exit 0"
  },
  "dependencies": {
    "@cavalry/audit": "workspace:*",
    "@cavalry/common": "workspace:*",
    "@cavalry/database": "workspace:*",
    "@cavalry/git-provider": "workspace:*",
    "@cavalry/git-sync": "workspace:*",
    "@cavalry/policy": "workspace:*",
    "@cavalry/slack": "workspace:*",
    "@cavalry/registry-upstream": "workspace:*",
    "@cavalry/skill-format": "workspace:*",
    "@paralleldrive/cuid2": "^2.2.2",
    "@playwright/test": "^1.59.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.13.1",
    "tar": "^7.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/pg": "^8.11.10",
    "@types/tar": "^6.1.13",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3"
  }
}
